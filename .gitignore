# --- Visual Studio ---
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.cache
*.ncb
*.sbr
*.bsp

# --- Build outputs ---
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]uild/
bld/
*.dll
*.exe
*.pdb
*.ilk
*.lib
*.exp
*.obj
*.res
*.resources
*.manifest
*.application
*.deploy
*.pubxml.user

# --- NuGet ---
packages/
*.nupkg
**/vendor/bin/

# --- PHP/Composer (LauncherSource API) ---
Client/LauncherSource/api/vendor/

# --- IIS / ASP.NET temp ---
_PublishedWebsites/
App_Data/

# --- Database backups ---
Database/*.bak

# --- Logs ---
logs/
*.log

# --- Windows ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Config backups ---
*.bak
*.config.bak
*.xml.bak

# --- Temp installers (generated by instalar_dependencias.bat) ---
temp_installers/

# --- Misc ---
*.swp
*.swo
*~
.DS_Store